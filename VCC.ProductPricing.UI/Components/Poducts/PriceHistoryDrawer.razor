<MudDrawer @bind-Open="@_open" Anchor="Anchor.End" Elevation="1" Variant="@DrawerVariant.Temporary" OverlayAutoClose="false">
    <MudDrawerHeader Class="d-flex justify-space-between ">
        <MudText Typo="Typo.h6">Price History</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="_ => _open = false">Close Drawer</MudButton>
    </MudDrawerHeader>

    @if (_product != null)
    {
        <MudText Typo="Typo.h6" Style="margin-bottom: 4vh;" Align="Align.Center">@_product.Name</MudText>
        <MudTimeline>

            @if (_product.PriceHistory != null)
            {
                int i = 1;
                foreach (var priceTime in _product.PriceHistory.OrderByDescending(p => p.Date))
                {
                    var col = i % 2 == 0 ? Color.Tertiary : Color.Primary;
                    <MudTimelineItem Color="@col" Elevation="25" TimelineAlign="TimelineAlign.End">
                        <ItemOpposite>
                            <MudText Color="Color.Default" Typo="Typo.h6">@priceTime.Date</MudText>
                        </ItemOpposite>
                        <ItemContent>
                            <MudText Color="@col" Typo="Typo.h6">@priceTime.Price.ToString("C")</MudText>
                        </ItemContent>
                    </MudTimelineItem>
                    i++;
                }
            }
        </MudTimeline>
    }
</MudDrawer>
@code {

    private bool _open;

    private Product? _product;

    public async Task OpenDrawer(int productId)
    {
        _product = await HttpClient.GetFromJsonAsync<Product>($"{Configuration.GetValue<string>("ApiUri")}api/products/{productId}", JsonOptions);

        _open = true;
        await InvokeAsync(StateHasChanged);
    }
}