@page "/"
@using System.Collections.ObjectModel
@using MudBlazor.Utilities
<PageTitle>Home</PageTitle>


<MudDataGrid @ref="_grid" Bordered="true" Dense="true" T="Product" Items="@_items" SortMode="SortMode.Multiple" Filterable="true" QuickFilter="@QuickFilter">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Products</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.Id" Title="#" Sortable="true" />
        <PropertyColumn Property="x => x.Name" />
        <PropertyColumn Property="x => x.LastUpdated" />
        <TemplateColumn  ShowColumnOptions="true" Title="Price" Sortable="true" SortBy="@GetPriceSortSelector()">
            <CellTemplate>
                @if (_discountDict.TryGetValue(context.Item.Id, out var discount))
                {
                    <MudText Typo="Typo.body2" Style="text-decoration: line-through; color: grey;">
                        @context.Item.Price.ToString("C")
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Error">
                        @discount.DiscountedPrice.ToString("C")
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2">@context.Item.Price.ToString("C")</MudText>
                }
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Options" CellClass="d-flex justify-between">
            <CellTemplate>
                <MudButtonGroup OverrideStyles="false">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" EndIcon="@Icons.Material.Filled.Timeline" OnClick="@(() => OpenTimeline(context.Item))">Price History</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" EndIcon="@Icons.Material.Filled.Discount" OnClick="@(() => OpenDiscount(context.Item))">Discount</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Tertiary" EndIcon="@Icons.Material.Filled.PriceChange" OnClick="@(() => OpenNewPrice(context.Item))">Price Change</MudButton>
                </MudButtonGroup>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="Product" />
    </PagerContent>
</MudDataGrid>

<PriceHistoryDrawer @ref="_historyDrawer"></PriceHistoryDrawer>
<DiscountDialog @ref="_discountDialog" OnDiscountSubmitted="HandleDiscountResult"></DiscountDialog>
<UpdatePriceDialog @ref="_updatePriceDialog" OnUpdatePriceSubmitted="HandleNewPriceResult"></UpdatePriceDialog>


@code {
    private ObservableCollection<Product> _items = new();
    private string _searchString = string.Empty;
    private PriceHistoryDrawer _historyDrawer = null!;
    private DiscountDialog _discountDialog = null!;
    private UpdatePriceDialog _updatePriceDialog = null!;
    private MudDataGrid<Product> _grid = null!;

    private readonly Dictionary<int, DiscountResponse> _discountDict = new();

    private async Task OpenTimeline(Product product)
    {
        await _historyDrawer.OpenDrawer(product.Id);
    }

    private void OpenDiscount(Product product)
    {
        _discountDialog.OpenDialog(product.Id);
    }

    private void HandleDiscountResult(DiscountResponse? result)
    {
        if (result is null) return;
        if (!_discountDict.TryAdd(result.Id, result))
            _discountDict[result.Id] = result;
        StateHasChanged();
    }

    private void OpenNewPrice(Product product)
    {
        _updatePriceDialog.OpenDialog(product.Id);
    }

    private async Task HandleNewPriceResult(UpdatePriceResponse? result)
    {
        if (result is null) return;
        _discountDict.Remove(result.Id);
        _items = await HttpClient.GetFromJsonAsync<ObservableCollection<Product>>($"{Configuration.GetValue<string>("ApiUri")}api/products", JsonOptions) ?? new ObservableCollection<Product>();
        StateHasChanged();
    }

    private Func<Product, object> GetPriceSortSelector() =>
        x => _discountDict.TryGetValue(x.Id, out var discount)
            ? discount.DiscountedPrice
            : x.Price;

    // quick filter - filter globally across multiple columns with the same input
    private Func<Product, bool> QuickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (x.LastUpdated.ToString("dd/MM/yyyy").Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;     
        
        if (x.Id.ToString().Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    };

    protected override async Task OnInitializedAsync()
    {
        _items = await HttpClient.GetFromJsonAsync<ObservableCollection<Product>>($"{Configuration.GetValue<string>("ApiUri")}api/products", JsonOptions) ?? new ObservableCollection<Product>();
    }
}