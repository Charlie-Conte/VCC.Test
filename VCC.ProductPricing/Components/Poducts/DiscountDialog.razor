<MudDialog @bind-Visible="_visible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Discount" Class="mr-3"/> Apply Discount
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudNumericField Format="0'%'" Required="true" Label="Discount Amount" AutoFocus="true" HelperText="Value of 0 to 100" T="int" @bind-Value="_discountInput" Class="mt-3" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitDiscount" Class="px-10">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public EventCallback<DiscountResponse?> OnDiscountSubmitted { get; set; }

    private bool _visible;
    private int _discountInput;
    private int _productId;
    private readonly DialogOptions _dialogOptions = new() { FullWidth = true, CloseButton = true};

    public void OpenDialog(int productId)
    {
        _discountInput = 0;
        _productId = productId;
        _visible = true;
        StateHasChanged();
    }
    
    private async Task SubmitDiscount()
    {
        var response = await HttpClient.PostAsJsonAsync($"{Configuration.GetValue<string>("ApiUri")}api/products/{_productId}/apply-discount", new DiscountRequest() { DiscountPercentage = _discountInput }, JsonOptions);
        string responseContent = await response.Content.ReadAsStringAsync();
        if (!response.IsSuccessStatusCode)
        {
            VccSnackbarService.ShowError(responseContent, response.ReasonPhrase);
            return;
        }

        _visible = false;

        var result = JsonSerializer.Deserialize<DiscountResponse>(responseContent, JsonOptions);
        await OnDiscountSubmitted.InvokeAsync(result);
    }
}